{
    "name": "fetsjr/livetabler",
    "description": "Tabler UI components for Livewire, inspired by Flux.",
    "keywords": ["tabler", "laravel", "livewire", "components", "ui"],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/view": "^10.0|^11.0|^12.0|^13.0",
        "livewire/livewire": "^3.7.4|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Tabler\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tabler\\TablerServiceProvider"
            ]
        }
    }
}
